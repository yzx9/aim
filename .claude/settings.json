{
  "permissions": {
    "allow": [
      "Bash(cargo test:*)",
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(just test:*)",
      "Bash(just lint:*)",
      "Skill(frontend-design)",
      "Skill(git-commit)",
      "WebFetch(domain:crates.io)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.agents/scripts/smart-format.sh"
          }
        ]
      }
    ]
  }
}
